# Bắt buộc cho OpenAI (embedding + chat)

# Tuỳ chọn — mặc định gpt-4o-mini nếu không set (trong rag_engine)
OPENAI_CHAT_MODEL=gpt-4o-mini

# Gốc web được phép gọi API (Vite dev + production), phân tách bằng dấu phẩy
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Backend Spring Boot — lưu báo giá vào MongoDB (POST /api/quotations)
SPRING_QUOTATION_API_URL=http://localhost:8080/api/quotations
